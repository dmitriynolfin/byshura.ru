RewriteEngine On
RewriteBase /

# Убираем .html из URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Редирект с .html на URL без расширения (301)
RewriteCond %{THE_REQUEST} \.html [NC]
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# Принудительно убираем trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Кэширование статических ресурсов
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Кэширование изображений на 1 год
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # Кэширование CSS/JS на 1 месяц
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  ExpiresByType application/json "access plus 1 month"
  ExpiresByType application/manifest+json "access plus 1 month"
</IfModule>

# Сжатие Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
  # Уровень сжатия (1-9)
  DeflateCompressionLevel 6
  # Сжатие для старых браузеров
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
</IfModule>

# Запрет индексации веб-роботам
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Отправка правильных MIME-типов
<IfModule mod_mime.c>
  AddType application/javascript js
  AddType text/css css
  AddType image/webp webp
  AddType image/svg+xml svg svgz
  AddType font/woff2 woff2
</IfModule>

# Ускорение загрузки через заголовки
<IfModule mod_headers.c>
  # Добавление заголовков для кэширования
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|woff|woff2|ttf|otf|svg|js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  
  # Запрет кэширования динамических страниц
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
</IfModule>

# Предотвращение hotlinking
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_REFERER} !^https?://(www\.)?byshura\.ru/.*$ [NC]
  RewriteCond %{HTTP_REFERER} !^$
  RewriteRule \.(jpe?g|png|gif|webp|svg)$ - [F,NC,L]
</IfModule>
