RewriteEngine On

# 1. Принудительный редирект с .html на чистый URL (без расширения)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. Внутреннее перенаправление: если запрошен чистый URL, сервер ищет файл .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
